PORT=3000
# Start a local MongoDB on this URI for persistent development data.
# If this URI is unreachable in NODE_ENV=development, the server falls back to temporary in-memory MongoDB.
MONGODB_URI=mongodb://127.0.0.1:27017/glazia-home-secure
JWT_SECRET=replace-this
JWT_EXPIRES_IN=7d
DEVICE_API_KEY=replace-this-too
PAIRING_SESSION_TTL_SECONDS=60
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_TOKEN=
META_WHATSAPP_API_VERSION=v22.0
WHATSAPP_OTP_TEMPLATE_NAME=login_otp
WHATSAPP_COUNTRY_CODE=91
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
